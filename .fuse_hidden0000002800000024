<script>
//=================== THAI PHRASEBOOK (same 50 phrases as V1) ===================
const PHRASES = [
  ["Hello / Welcome","สวัสดีครับ","Sa-wat-dee krap"],
  ["Thank you","ขอบคุณครับ","Khop-khun krap"],
  ["Yes","ใช่","Chai"],
  ["No","ไม่","Mai"],
  ["How much?","เท่าไหร่","Tao-rai?"],
  ["Too expensive","แพงไป","Paeng pai"],
  ["Can you lower the price?","ลดได้ไหม","Lot dai mai?"],
  ["Where is the toilet?","ห้องน้ำอยู่ที่ไหน","Hong-nam yoo tee-nai?"],
  ["Delicious","อร่อย","A-roi"],
  ["Not spicy","ไม่เผ็ด","Mai pet"],
  ["A little spicy","เผ็ดนิดหน่อย","Pet nit-noi"],
  ["The bill, please","เก็บเงินครับ","Geb ngern krap"],
  ["Water","น้ำ","Nam"],
  ["One beer, please","ขอเบียร์หนึ่ง","Kor bia neung"],
  ["Cheers!","ชนแก้ว","Chon-gaeo!"],
  ["Excuse me / Sorry","ขอโทษครับ","Kor-tot krap"],
  ["No problem / Never mind","ไม่เป็นไร","Mai pen rai"],
  ["I don't understand","ไม่เข้าใจ","Mai kao-jai"],
  ["Do you speak English?","พูดภาษาอังกฤษได้ไหม","Poot pasa Angkrit dai mai?"],
  ["Please speak slowly","พูดช้าๆ","Poot cha-cha"],
  ["Where?","ที่ไหน","Tee-nai?"],
  ["Hotel","โรงแรม","Rong-raem"],
  ["Airport","สนามบิน","Sa-nam-bin"],
  ["Taxi","แท็กซี่","Taxi"],
  ["Stop here","จอดตรงนี้","Jot trong-nee"],
  ["Left","ซ้าย","Sai"],
  ["Right","ขวา","Kwaa"],
  ["Go straight","ตรงไป","Trong pai"],
  ["How are you?","สบายดีไหม","Sabai-dee mai?"],
  ["I'm fine","สบายดี","Sabai-dee"],
  ["What's your name?","คุณชื่ออะไร","Khun cheu a-rai?"],
  ["My name is...","ผมชื่อ...","Pom cheu..."],
  ["Beautiful","สวย","Suay"],
  ["Handsome","หล่อ","Lor"],
  ["Friend","เพื่อน","Peuan"],
  ["I like it","ชอบ","Chop"],
  ["I don't want it","ไม่เอา","Mai ao"],
  ["I want this one","เอาอันนี้","Ao an-nee"],
  ["Help!","ช่วยด้วย","Chuay duay!"],
  ["Hospital","โรงพยาบาล","Rong-pa-ya-baan"],
  ["Police","ตำรวจ","Tam-ruat"],
  ["Expensive","แพง","Paeng"],
  ["Cheap","ถูก","Took"],
  ["Hot (weather)","ร้อน","Ron"],
  ["Cold","หนาว","Nao"],
  ["Good","ดี","Dee"],
  ["Very good","ดีมาก","Dee mak"],
  ["See you again","แล้วเจอกัน","Laeo jer gan"],
  ["Goodbye","ลาก่อน","Laa gon"],
  ["Good luck","โชคดี","Chok dee"]
];
// category per phrase (index-aligned): G=Greetings & Basics, A=Getting Around, F=Food & Markets, N=Nightlife & Social, E=Emergencies
const PHRASE_CAT_CODE = 'GGGGFFFAFFFFFNNGGGGGAAAAAAAAGGNNNNNFFFEEEFFGGGGGGG';
const PHRASE_CATS = { G:'🙏 Greetings & Basics', A:'🛺 Getting Around', F:'🍜 Food & Markets', N:'🍻 Nightlife & Social', E:'🚨 Emergencies' };
let phraseFilter='ALL';
const $ = id => document.getElementById(id);

function renderPhraseCats(){
  const cats = ['ALL', ...Object.keys(PHRASE_CATS)];
  $('phraseCats').innerHTML = cats.map(cd=>{
    const label = cd==='ALL' ? 'All 50' : PHRASE_CATS[cd];
    const on = phraseFilter===cd;
    return `<button type="button" onclick="setPhraseCat('${cd}')" aria-pressed="${on}" class="px-3 py-2 rounded-full text-xs font-bold transition ${on?'btn-teal':'btn-ghost'}">${label}</button>`;
  }).join('');
}
function setPhraseCat(cd){ phraseFilter=cd; renderPhraseCats(); renderPhrases(); }

function renderPhrases(){
  const items = PHRASES.map((p,i)=>({p,i,cat:PHRASE_CAT_CODE[i]}))
    .filter(x=> (phraseFilter==='ALL' || x.cat===phraseFilter));
  $('phraseList').innerHTML = items.length ? items.map(({p,i,cat})=>`
    <button type="button" onclick="copyPhrase(${i}, this)" class="opt p-4 text-left group relative" aria-label="Copy phrase: ${p[0]}">
      <div class="flex items-start justify-between gap-2">
        <div class="min-w-0">
          <p class="font-bold text-sm">${p[0]}</p>
          <p class="text-lg text-tealdeep mt-0.5">${p[1]}</p>
          <p class="text-sm font-semibold text-coral mt-0.5">${p[2]}</p>
        </div>
        <span class="text-ink/25 group-hover:text-tealdeep transition text-base shrink-0" aria-hidden="true">📋</span>
      </div>
      <span class="absolute bottom-2 right-3 text-[10px] text-ink/30 font-semibold">${PHRASE_CATS[cat]}</span>
    </button>`).join('')
    : '';
}
function copyPhrase(i, el){
  const p = PHRASES[i];
  const txt = `${p[0]} — ${p[1]} (${p[2]})`;
  navigator.clipboard && navigator.clipboard.writeText(txt).then(()=>{
    const badge = el.querySelector('span[aria-hidden]');
    if(badge){ const old=badge.textContent; badge.textContent='✅'; setTimeout(()=>badge.textContent=old,1200); }
  }).catch(()=>{});
}

//=================== THEME (dark default) ===================
function applyThemeIcon(){
  const dark = document.documentElement.classList.contains('dark');
  const b = document.getElementById('themeBtn'); if(b) b.innerHTML = dark ? '☀️ Light' : '🌙 Dark';
}
function toggleTheme(){
  const el = document.documentElement;
  el.classList.toggle('dark');
  try{ localStorage.setItem('pong_theme', el.classList.contains('dark') ? 'dark' : 'light'); }catch(e){}
  applyThemeIcon();
}

renderPhraseCats(); renderPhrases(); applyThemeIcon();
</script>
</body>
