# _headers — Netlify / Cloudflare Pages
# Place at the site root. Cloudflare Pages and Netlify both read this file.
# NOTE: the Content-Security-Policy is shipped as Report-Only first (see the
# guide). Once the browser console shows zero violations for a week, rename the
# header to Content-Security-Policy to enforce it.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), browsing-topics=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: SAMEORIGIN
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Content-Security-Policy-Report-Only: default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; object-src 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://pagead2.googlesyndication.com https://www.googletagmanager.com https://*.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https:; frame-src https://googleads.g.doubleclick.net https://*.google.com; upgrade-insecure-requests

# Long-cache immutable static media (rename the file when you change an image)
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable

# HTML must revalidate so 2026 price edits go live immediately
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Utility page: keep out of the index, keep links followed
/cookie-settings.html
  X-Robots-Tag: noindex, follow

# Rollback copy: never index, never follow
/index-v1-backup.html
  X-Robots-Tag: noindex, nofollow
