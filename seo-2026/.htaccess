# .htaccess — Apache (shared hosting / cPanel)
# thaiholidaybudget.com — canonical host https://thaiholidaybudget.com (non-www)

# ============================================================
# 1. Force HTTPS + non-www canonical host (single 301 hop)
# ============================================================
RewriteEngine On
# a) www -> non-www (and force https at the same time)
RewriteCond %{HTTP_HOST} ^www\.thaiholidaybudget\.com$ [NC]
RewriteRule ^ https://thaiholidaybudget.com%{REQUEST_URI} [L,R=301]
# b) any http -> https
RewriteCond %{HTTPS} off
RewriteRule ^ https://thaiholidaybudget.com%{REQUEST_URI} [L,R=301]

# ============================================================
# 2. Security / trust headers (E-E-A-T + user safety)
# ============================================================
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), browsing-topics=()"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
  # HSTS only over HTTPS
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" "expr=%{HTTPS} == 'on'"

  # Per-file indexing controls
  <FilesMatch "cookie-settings\.html$">
    Header set X-Robots-Tag "noindex, follow"
  </FilesMatch>
  <FilesMatch "index-v1-backup\.html$">
    Header set X-Robots-Tag "noindex, nofollow"
  </FilesMatch>
</IfModule>

# ============================================================
# 3. Compression
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml \
    application/javascript application/json application/xml image/svg+xml \
    application/rss+xml font/ttf font/otf
</IfModule>

# ============================================================
# 4. Caching
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html               "access plus 0 seconds"
  ExpiresByType text/css                "access plus 1 year"
  ExpiresByType application/javascript  "access plus 1 year"
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/webp              "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType image/x-icon            "access plus 1 year"
</IfModule>

# ============================================================
# 5. Correct charset + block access to VCS / dotfiles
# ============================================================
AddDefaultCharset UTF-8
RewriteCond %{REQUEST_URI} (^|/)\.(git|env)(/|$) [NC]
RewriteRule ^ - [F]
