<script>
  function applyThemeIcon(){var b=document.getElementById('themeBtn');if(b)b.innerHTML=document.documentElement.classList.contains('dark')?'☀️ Light':'🌙 Dark';}
  function toggleTheme(){var el=document.documentElement;el.classList.toggle('dark');try{localStorage.setItem('pong_theme',el.classList.contains('dark')?'dark':'light');}catch(e){}applyThemeIcon();}
  applyThemeIcon();

  const ESTIMATE_KEY='somchai_pattaya_v1', NOTICE_KEY='somchai_cookie_ok';
  function flash(t){ const m=document.getElementById('msg'); m.textContent=t; setTimeout(()=>m.textContent='',2600); }
  function render(){
    let est=null, notice=null;
    try{ est=localStorage.getItem(ESTIMATE_KEY); notice=localStorage.getItem(NOTICE_KEY); }catch(e){}
    const rows=[];
    rows.push(`<div class="flex justify-between py-1 border-b border-current/10"><span>Saved estimate <code class="opacity-50">${ESTIMATE_KEY}</code></span><span>${est?'<b class="text-tealdeep">present</b> ('+est.length+' chars)':'<span class="opacity-50">empty</span>'}</span></div>`);
    rows.push(`<div class="flex justify-between py-1"><span>Notice preference <code class="opacity-50">${NOTICE_KEY}</code></span><span>${notice?'<b class="text-tealdeep">set</b>':'<span class="opacity-50">empty</span>'}</span></div>`);
    document.getElementById('storageBox').innerHTML = rows.join('');
  }
  function clearEstimate(){ try{ localStorage.removeItem(ESTIMATE_KEY); }catch(e){} render(); flash('✅ Saved estimate cleared.'); }
  function clearAll(){ try{ localStorage.removeItem(ESTIMATE_KEY); localStorage.removeItem(NOTICE_KEY); localStorage.removeItem(PREF_KEY); }catch(e){} loadPrefs(); render(); flash('✅ All stored data cleared from this device.'); }

  const PREF_KEY='somchai_cookie_prefs';
  function loadPrefs(){
    let p={}; try{ p=JSON.parse(localStorage.getItem(PREF_KEY))||{}; }catch(e){}
    const a=document.getElementById('pref_analytics'), ad=document.getElementById('pref_ads');
    if(a) a.checked=!!p.analytics;
    if(ad) ad.checked=!!p.ads;
  }
  function savePrefs(analytics, ads){
    try{ localStorage.setItem(PREF_KEY, JSON.stringify({necessary:true, analytics:!!analytics, ads:!!ads, ts:Date.now()})); localStorage.setItem(NOTICE_KEY,'1'); }catch(e){}
    loadPrefs(); render(); flash('✅ Preferences saved on this device.');
  }
  function prefSave(){ savePrefs(document.getElementById('pref_analytics').checked, document.getElementById('pref_ads').checked); }
  function prefAccept(){ savePrefs(true, true); }
  function prefReject(){ savePrefs(false, false); }

  loadPrefs(); render();
</script>
