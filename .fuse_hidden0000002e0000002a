  .btn-ghost{background:var(--surface);border:1.5px solid var(--field-border);font-weight:700;transition:.15s;color:rgb(var(--ink-rgb))}
  .btn-ghost:hover{border-color:#14B8A6;color:var(--accent)}
  a.link{color:var(--accent);text-decoration:underline}
  html.dark .text-tealdeep{color:#2DD4BF}
