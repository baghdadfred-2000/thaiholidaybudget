<style>
  /* ---------- theme tokens: light (default) vs dark (deep navy) ---------- */
  :root{
    color-scheme:light;
    --page:#FFFBF0; --dot1:rgba(15,118,110,.045); --dot2:rgba(249,115,22,.03);
    --ink-rgb:31 41 55;
    --surface:#ffffff; --surface2:#ffffff;
    --card-border:rgba(15,118,110,.10); --field-border:#E2DCCD;
    --glass:rgba(255,251,240,.85); --glass-border:rgba(15,118,110,.12);
    --accent:#0F766E;
  }
  html.dark{
    color-scheme:dark;
    --page:#0A1428; --dot1:rgba(20,184,166,.05); --dot2:rgba(249,115,22,.04);
    --ink-rgb:230 237 248;
    --surface:#0F1D36; --surface2:#0C182E;
    --card-border:rgba(20,184,166,.20); --field-border:#243456;
    --glass:rgba(8,16,32,.85); --glass-border:rgba(20,184,166,.18);
    --accent:#2DD4BF;
  }
  html{-webkit-tap-highlight-color:transparent}
  body{
    background-color:var(--page);
    background-image:radial-gradient(var(--dot1) 1px, transparent 1px),radial-gradient(var(--dot2) 1px, transparent 1px);
    background-size:34px 34px,34px 34px; background-position:0 0,17px 17px;
    color:rgb(var(--ink-rgb));
    transition:background-color .25s, color .25s;
  }
  .glassbar{background:var(--glass);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:1px solid var(--glass-border)}
  .card{background:var(--surface);border:1px solid var(--card-border);border-radius:1.25rem;box-shadow:0 1px 2px rgba(15,118,110,.06),0 8px 24px -8px rgba(31,41,55,.10)}
  html.dark .card{box-shadow:0 1px 2px rgba(0,0,0,.3),0 8px 24px -8px rgba(0,0,0,.5)}
  .tile{background:var(--surface2);border:1px solid var(--card-border);border-radius:1rem}
  .btn-cta{background:linear-gradient(92deg,#F97316,#FB923C);color:#fff;font-weight:800;box-shadow:0 6px 20px -6px rgba(249,115,22,.55);transition:transform .15s,box-shadow .2s,filter .15s}
